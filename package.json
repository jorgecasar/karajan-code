{
  "name": "karajan-code",
  "version": "1.53.1",
  "description": "Local multi-agent coding orchestrator with TDD, SonarQube, and code review pipeline",
  "type": "module",
  "license": "AGPL-3.0",
  "author": "Manu Fosela <mjfosela@gmail.com>",
  "homepage": "https://github.com/manufosela/karajan-code#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manufosela/karajan-code.git"
  },
  "bugs": {
    "url": "https://github.com/manufosela/karajan-code/issues"
  },
  "keywords": [
    "ai",
    "orchestrator",
    "code-review",
    "tdd",
    "sonarqube",
    "multi-agent",
    "mcp",
    "cli"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/",
    "bin/",
    "templates/",
    "scripts/",
    "docs/karajan-code-logo-small.png",
    "docs/README.es.md",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "kj": "bin/kj.js",
    "kj-tail": "bin/kj-tail",
    "karajan-mcp": "bin/karajan-mcp.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "setup": "node scripts/install.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "((command -v rg >/dev/null 2>&1 && rg --files src tests | rg '\\.js$') || find src tests -type f -name '*.js') | while IFS= read -r f; do node --check \"$f\"; done",
    "validate": "npm run lint && npm test",
    "mcp": "node src/mcp/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.0"
  }
}
